<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/statsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_blue"
    tools:context=".Stats">

    <TextView
        android:id="@+id/tvStatsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Stats"
        android:textStyle="bold"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:layout_marginTop="56dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvStatsSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Track your progress over time"
        android:textSize="14sp"
        android:textColor="#CCE3DE"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatsTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/statsCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="130dp"
        android:background="@drawable/bg_card_top_rounded"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="100dp">

            <!-- Stat pills row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_pill"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvWorkoutsCompleted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#0078AE" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Workouts"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:gravity="center" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_pill"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvCurrentStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0🔥"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#0078AE" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Day Streak"
                        android:textSize="11sp"
                        android:textColor="#555555"
                        android:gravity="center" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_pill"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvLastWorkout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#0078AE" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Last Active"
                        android:textColor="#555555"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Weekly Activity / Calendar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Weekly Activity"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:id="@+id/tvCalendarMonthYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="April 2026"
                    android:textSize="13sp"
                    android:textColor="#0078AE"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCalendarPrev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="‹"
                    android:textSize="20sp"
                    android:textColor="#0078AE"
                    android:gravity="center"
                    android:layout_marginStart="8dp" />

                <TextView
                    android:id="@+id/tvCalendarNext"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="›"
                    android:textSize="20sp"
                    android:textColor="#0078AE"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Calendar card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_pill"
                android:padding="12dp">

                <!-- Day headers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="7">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Su" android:gravity="center" android:textSize="11sp" android:textColor="#0078AE" android:textStyle="bold" android:paddingBottom="6dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mo" android:gravity="center" android:textSize="11sp" android:textColor="#0078AE" android:textStyle="bold" android:paddingBottom="6dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tu" android:gravity="center" android:textSize="11sp" android:textColor="#0078AE" android:textStyle="bold" android:paddingBottom="6dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="We" android:gravity="center" android:textSize="11sp" android:textColor="#0078AE" android:textStyle="bold" android:paddingBottom="6dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Th" android:gravity="center" android:textSize="11sp" android:textColor="#0078AE" android:textStyle="bold" android:paddingBottom="6dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fr" android:gravity="center" android:textSize="11sp" android:textColor="#0078AE" android:textStyle="bold" android:paddingBottom="6dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sa" android:gravity="center" android:textSize="11sp" android:textColor="#0078AE" android:textStyle="bold" android:paddingBottom="6dp" />

                </LinearLayout>

                <!-- Calendar grid — populated dynamically by StatsActivity.java -->
                <GridLayout
                    android:id="@+id/calendarGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="7"
                    android:useDefaultMargins="false" />

            </LinearLayout>

            <!-- Calendar legend -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/bg_cal_day_workout" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Workout scheduled"
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:layout_marginEnd="12dp" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/bg_cal_day_done" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Completed"
                    android:textSize="11sp"
                    android:textColor="#555555" />

            </LinearLayout>

            <!-- Water Intake -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Water Intake"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/waterTapArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_pill"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Daily Water Goal"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginStart="10dp" />

                    <TextView
                        android:id="@+id/tvWaterAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 2000 ml"
                        android:textSize="12sp"
                        android:textColor="#0078AE"
                        android:textStyle="bold" />

                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_water_track">

                    <LinearLayout
                        android:id="@+id/waterMeterFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_water_fill"
                        android:orientation="horizontal" />

                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap to log +250ml"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- Recent Workouts -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Workouts"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_stat_pill"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏋️"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvRecentWorkout1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No workouts yet"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:id="@+id/tvRecentWorkout1Date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete your first workout!"
                        android:textSize="12sp"
                        android:textColor="#777777"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↗"
                    android:textSize="16sp"
                    android:textColor="#0078AE" />

            </LinearLayout>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditSchedule"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="✏️  Edit Schedule"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#0078AE"
                app:cornerRadius="28dp"
                app:elevation="0dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>