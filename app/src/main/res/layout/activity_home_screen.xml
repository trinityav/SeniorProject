<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_blue"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/homeContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="100dp">

        <!-- Greeting text -->
        <TextView
            android:id="@+id/greetingText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="48dp"
            android:text="Hi Student, Lets check Your Activity!"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:lineSpacingMultiplier="1.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Upcoming Workout Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/upcomingWorkoutCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F0FAF0"
            app:layout_constraintTop_toBottomOf="@id/greetingText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upcoming Workout"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0078AE" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCE3DE"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="14dp" />

                <!-- Date row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="20sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvUpcomingDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No upcoming workout scheduled"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E" />

                        <TextView
                            android:id="@+id/tvUpcomingWorkoutName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Schedule one in the Stats page"
                            android:textSize="12sp"
                            android:textColor="#777777"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="↗"
                        android:textSize="16sp"
                        android:textColor="#555555"
                        android:gravity="center"
                        android:background="@drawable/bg_arrow_circle" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCE3DE"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp" />

                <!-- Total Workouts Completed stat -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Workouts Completed"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:layout_marginStart="12dp" />

                    <TextView
                        android:id="@+id/tvTotalWorkouts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#0078AE" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- AI Chat card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/aiChatCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F0FAF0"
            app:layout_constraintTop_toBottomOf="@id/upcomingWorkoutCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖"
                    android:textSize="28sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/aiChatText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chat with AI Coach"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ask anything about your workouts"
                        android:textSize="12sp"
                        android:textColor="#777777"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="↗"
                    android:textSize="16sp"
                    android:textColor="#555555"
                    android:gravity="center"
                    android:background="@drawable/bg_arrow_circle" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Start Workout button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startWorkoutButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:text="Start Workout"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#4AA948"
            app:cornerRadius="28dp"
            app:elevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/aiChatCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>