<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Workout Name"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#0078AE"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etDialogWorkoutName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="e.g. Chest Day, HIIT, Run"
        android:inputType="textCapSentences"
        android:padding="8dp"
        android:backgroundTint="#0078AE" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notes (optional)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#0078AE"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etDialogNotes"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:hint="Any details about this session..."
        android:inputType="textMultiLine"
        android:gravity="top"
        android:padding="8dp"
        android:backgroundTint="#0078AE" />

</LinearLayout>